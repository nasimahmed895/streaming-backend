PORT=3434
# Set to 'production' in production environments to enable security features or development features in development. Default is 'development'.
NODE_ENV=development

# RTMP server port (OBS connects here)
RTMP_PORT=1935

# Optional: OBS stream key prefix validation (leave empty to allow all keys)
# STREAM_SECRET=your_secret_here

# Auto-cleanup stale stream dirs after N minutes
CLEANUP_AFTER_MINUTES=30

# Admin key to protect management API endpoints (leave empty = open in dev)
ADMIN_KEY=change_this_secret

# Allowed domains — only these can load HLS streams in production
# Comma-separated, no protocol, supports subdomains automatically
# Leave empty = allow all (dev convenience)
ALLOWED_DOMAINS=yourdomain.com,app.yourdomain.com,localhost

# Session TTL in hours (default 4)
SESSION_TTL_HOURS=4

# Public URL of this server (used in HLS key URI embedded in m3u8)
SERVER_URL=http://localhost:3434
