PORT=3434
NODE_ENV=development

# RTMP server port (OBS connects here)
RTMP_PORT=1935

# Optional: stream key validation (leave empty to allow all keys)
# STREAM_SECRET=your_secret_here

# Auto-cleanup stale streams after N minutes
CLEANUP_AFTER_MINUTES=30

# Viewer token TTL in hours (default 4)
TOKEN_TTL_HOURS=4

# Admin key to protect token generation endpoints (leave empty = open in dev)
# ADMIN_KEY=change_this_secret
